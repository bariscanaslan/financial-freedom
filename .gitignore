# ============================================================================
# VERI VE MODEL CIKTILARI
# ============================================================================
# Bunlar URETILEBILIR: yfinance'ten yeniden indirilir, model yeniden egitilir.
# Repoyu sismekten korumak icin disarida tutuluyorlar.

# Indirilmis OHLCV parquet cache'i (data/config.py -> CACHE_DIR)
cache/

# Kullanici portfolyo event log'lari (portfolio/config.py -> PORTFOLIO_DIR).
# Kisisel islem verisi -- repoya girmez.
portfolio_data/

# Egitilmis modeller: model.pt (binary agirliklar) + meta.json
#
# NOT -- DENETLENEBILIRLIK: bir modeli URETIME alirsan, o modelin
# meta.json'ini (scaler, cfg, test metrikleri, git commit) commit etmek
# ISTEYEBILIRSIN. Binary agirliklar git'e ait degil, ama "uretimde su an
# hangi model var ve skoru neydi" sorusunun cevabi repoda durmali.
# O durumda ilgili dosyayi acikca ekle:
#     git add -f models/AAPL_20260714_120000/meta.json
#
# 'models/' degil 'models/*' -- git, ust dizini dislanmis bir dosyayi geri
# alamaz. Dizini disarida birakirsak asagidaki !models/.gitkeep calismaz.
models/*
!models/.gitkeep

# ------------------------------------------------------------------- loglar
*.log
logs/

