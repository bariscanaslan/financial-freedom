VPN_BIND_ADDRESS=127.0.0.1
FRONTEND_PORT=3007
BACKEND_PORT=8089
REDIS_PORT=6389

# VPN'den erişim için VPN_BIND_ADDRESS değerini sunucunun VPN arayüz IP'si yapın.
# Örnek Tailscale: VPN_BIND_ADDRESS=100.64.0.10
# Örnek WireGuard: VPN_BIND_ADDRESS=10.8.0.1