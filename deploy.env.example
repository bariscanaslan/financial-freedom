# Bu sablonu Jenkins Secret file credential olarak yukleyin.
# Jenkins container ve Docker host DEPLOY_DIR yolunu ayni mutlak yolda gormeli.
DEPLOY_DIR=/home/bariscanaslan/AppData/financial-freedom
DEPLOY_PROJECT_NAME=financial-freedom

# Varsayilan yalnizca localhost'tan erisimdir. VPN erisimi icin sunucunun
# WireGuard/Tailscale arayuz IP adresini yazin.
VPN_BIND_ADDRESS=127.0.0.1
FRONTEND_PORT=3007
BACKEND_PORT=8089
REDIS_PORT=6389
